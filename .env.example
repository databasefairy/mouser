# Get your API key from https://platform.openai.com/api-keys
# Put the ENTIRE key on ONE line (no line break in the middle). Using quotes avoids accidental truncation:
OPENAI_API_KEY="sk-proj-paste-your-full-key-here-on-one-line"

# ALTERNATIVE: If .env keeps truncating the key, put ONLY the key (no variable name) in a file named .env.openai_key
# One line, 164 chars, nothing else. The app will use it if OPENAI_API_KEY is too short.

# Optional: model for job search (default: gpt-4o). Must support web_search in Responses API.
# OPENAI_JOB_MODEL=gpt-4o
