# Job search uses Gemini. Get an API key at https://aistudio.google.com/apikey
# Put the key on one line. Use either variable name:
GEMINI_API_KEY=your-gemini-api-key
# or GOOGLE_API_KEY=your-google-api-key

# --- Login (NextAuth) ---
# Required for login. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-at-least-32-chars
# Full URL of your app — no trailing slash. Local: http://localhost:3000. Production (Vercel): https://mouser-inky.vercel.app
NEXTAUTH_URL=http://localhost:3000

# --- User Management ---
# Each user must log in with their specific username AND password.
#
# OPTION 1 - SUPABASE (recommended for production):
# Set these env vars and create a 'users' table (see SQL below)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
#
# OPTION 2 - LOCAL DEVELOPMENT: Users stored in data/users.json. Create via Admin Panel.
# Default admin password (used on first startup):
MOUSER_ADMIN_PASSWORD=admin123
#
# OPTION 3 - VERCEL WITHOUT SUPABASE: Set MOUSER_USERS env var with JSON
# MOUSER_USERS={"users":[{"username":"admin","password":"yourpassword","role":"admin","searchCount":0,"lastSearchDate":"","createdAt":"2024-01-01T00:00:00.000Z"}]}
#
# Roles:
# - user: Basic login, 5 searches per day
# - power_user: Unlimited searches (no debug/admin access)
# - admin: Unlimited searches + Debug page + Admin Panel
