# Job search uses Gemini. Get an API key at https://aistudio.google.com/apikey
# Put the key on one line. Use either variable name:
GEMINI_API_KEY=your-gemini-api-key
# or GOOGLE_API_KEY=your-google-api-key

# --- Login (NextAuth) ---
# Required for login. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-at-least-32-chars
# Full URL of your app — no trailing slash. Local: http://localhost:3000. Production (Vercel): https://mouser-inky.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Simple password login. If set, users can sign in with any username + this password.
MOUSER_LOGIN_PASSWORD=your-shared-password

# Rate-limit bypass (optional). If set, signing in with this password (any username) disables rate limits (shows "Unlimited").
# MOUSER_RATE_LIMIT_EXEMPT_PASSWORD=your-exempt-password
